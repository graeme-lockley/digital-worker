# syntax=docker/dockerfile:1
# Builds agent-core from the monorepo root (compose build context: project root).
# The build stage matches Dockerfile.agent-register — keep both in sync.

FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@11.5.0 --activate
WORKDIR /app

FROM base AS build
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json .npmrc ./
COPY packages ./packages
COPY apps ./apps
COPY workspace ./workspace
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @digital-worker/agent-core-protocol run build \
  && pnpm --filter @digital-worker/agent-register-protocol run build \
  && pnpm --filter @digital-worker/agent-register run build \
  && pnpm --filter @digital-worker/agent-core run build

FROM node:22-bookworm-slim AS runtime
RUN corepack enable && corepack prepare pnpm@11.5.0 --activate
# Shell/tooling for the agent workspace (bash builtin, pip, git, ssh).
RUN apt-get update && apt-get install -y --no-install-recommends \
  python3 \
  python3-pip \
  curl \
  git \
  openssh-client \
  build-essential \
  ca-certificates \
  && rm -rf /var/lib/apt/lists/*
# agent-browser CLI + browser binary. amd64: Chrome for Testing via agent-browser.
# arm64: Chrome for Testing is unavailable — use Debian chromium + AGENT_BROWSER_EXECUTABLE_PATH.
RUN npm install -g agent-browser \
  && arch="$(dpkg --print-architecture)" \
  && if [ "$arch" = "arm64" ]; then \
       apt-get update \
       && apt-get install -y --no-install-recommends chromium \
       && rm -rf /var/lib/apt/lists/* \
       && printf 'AGENT_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium\n' > /etc/agent-browser.env; \
     else \
       agent-browser install --with-deps; \
     fi
COPY --from=build /app /app
WORKDIR /app/apps/agent-core
COPY infra/dev-workstation/agent-core-restart-loop.sh ./restart-loop.sh
RUN chmod +x ./restart-loop.sh
EXPOSE 3000
ENTRYPOINT ["/app/apps/agent-core/restart-loop.sh"]
CMD ["node", "dist/index.js", "--host", "0.0.0.0", "--port", "3000"]
