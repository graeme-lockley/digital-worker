{
  "name": "@digital-worker/agent-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "agent-core": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@digital-worker/agent-core-protocol": "workspace:*",
    "@digital-worker/agent-register-protocol": "workspace:*",
    "@earendil-works/pi-agent-core": "0.75.5",
    "@earendil-works/pi-ai": "0.75.5",
    "@earendil-works/pi-coding-agent": "0.75.5",
    "@hono/node-server": "^1.14.4",
    "commander": "^14.0.0",
    "hono": "^4.7.10",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
