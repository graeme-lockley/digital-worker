{
  "name": "digital-worker",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --if-present run build",
    "dev": "pnpm -r --parallel --if-present run dev",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm run test:packages && pnpm run test:apps",
    "test:packages": "pnpm -r --filter './packages/*' --if-present run test",
    "test:apps": "pnpm -r --filter './apps/*' --if-present run test",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
